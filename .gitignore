# ── 환경변수 / API 키 파일 (절대 GitHub에 올라가면 안 됨) ──
.env
.env.local
.env.production
*.key

# ── Python 캐시 ──
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# ── 데이터 및 설정 파일 (GitHub 저장을 위해 예외 처리) ──
data/*.json
!data/subscribers_prebid.json
!data/state.json
config/admins.json
!config/admins.json

# ── 테스트/IDE ──
.pytest_cache/
.vscode/
.idea/
*.swp
*.swo
.DS_Store
